# Devenv
.devenv*
devenv.local.nix
devenv.local.yaml

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml

# --- Python ---
__pycache__/
*.py[cod]
*.so
*.egg-info/
.venv/
dist/
build/

# --- Riva NIM ---
server/deploy/nim-cache/

# --- 検証用音声サンプル ---
/sample.wav
/*.wav

# --- Rust / Tauri ---
/target/
client/target/
client/src-tauri/target/
client/src-tauri/gen/

# --- Node ---
node_modules/
npm-debug.log*

# --- Vite ---
client/dist/

# --- koecast クライアント設定 ---
# 実体はユーザー環境固有 (Tailscale 名・ホットキー等)。
# リポジトリには client/config.toml.example のみコミットし、実体はコピーして使う。
# 通常は OS 標準 config dir (Mac: ~/Library/Application Support/koecast/) に置くので
# リポジトリ内には来ないが、保険として除外。
client/config.toml

# --- editors / OS ---
.DS_Store
.idea/
.vscode/
*.swp
