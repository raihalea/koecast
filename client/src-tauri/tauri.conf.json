{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "koecast",
  "version": "0.1.0",
  "identifier": "com.koecast.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "koecast",
        "width": 800,
        "height": 600,
        "visible": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "decorations": false,
        "alwaysOnTop": true,
        "focus": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "width": 520,
        "height": 96,
        "x": 100,
        "y": 60
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
